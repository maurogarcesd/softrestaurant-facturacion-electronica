# Entorno (local, production)
APP_ENV=local

# Base de datos de Integración (MySQL - Tu servidor local o Docker)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=integracion_factus
DB_USERNAME=root
DB_PASSWORD=

# Base de datos de SoftRestaurant (SQL Server)
SR_DB_HOST=127.0.0.1
SR_DB_PORT=1433
SR_DB_DATABASE=softrestaurant95pro
SR_DB_USERNAME=sa
SR_DB_PASSWORD=tu_contrasena_sqlserver

# Proveedor de Facturación (factus | datainvoice)
BILLING_PROVIDER=factus

# Umbral para alerta de soporte (WhatsApp)
ALERT_THRESHOLD="5"

# ---------------------------------------------------------
# CONFIGURACIÓN GENERAL DE IMPUESTOS Y EMISOR
# ---------------------------------------------------------
# Tasa de impuesto por defecto (ej: 8.00 para INC, 19.00 para IVA)
DEFAULT_TAX_RATE="8.00"
# Matrícula Mercantil (Obligatorio para la DIAN si aplica)
MERCHANT_REGISTRATION="0000000"

# ---------------------------------------------------------
# CONFIGURACIÓN DATAINVOICE
# ---------------------------------------------------------
# Identificadores de impuestos y obligaciones para DataInvoice
# tax_id: 4 = INC, 1 = IVA
DATAINVOICE_TAX_ID="4"
# regime_id: 2 = No responsable de IVA
DATAINVOIME_REGIME_ID="2"
# liability_id: 7 = No responsable de IVA
DATAINVOICE_LIABILITY_ID="7"

# Credenciales API Factus (V2)
# Para pasar a producción, comenta la línea de Sandbox y descomenta la de Producción
FACTUS_API_URL=https://api-sandbox.factus.com.co
# FACTUS_API_URL=https://api.factus.com.co

# Código de Unidad de Medida DIAN (94 = Unidad)
FACTUS_UNIT_MEASURE_CODE="94"
# Identificadores de impuestos para Factus
# 5 = INC, 1 = IVA
FACTUS_TAX_ID="5"
# 04 = INC, 01 = IVA
FACTUS_TAX_CODE="04"
# INC o IVA
FACTUS_TAX_NAME="INC"

# Credenciales de Autenticación Factus
FACTUS_EMAIL=tu_usuario@factus.com.co
FACTUS_PASSWORD=tu_contrasena_factus
FACTUS_CLIENT_ID=tu_client_id_guid
FACTUS_CLIENT_SECRET=tu_client_secret_token

# Credenciales API DataInvoice (Ambiente de PRUEBAS/PRODUCCIÓN)
DATAINVOICE_API_URL=https://api.datainvoicecolombia.com/api/ubl2.1
DATAINVOICE_NIT="tu_nit_emisor_sin_dv"
DATAINVOICE_TOKEN=tu_token_datainvoice_aqui

# Resolución DIAN asignada para pruebas/producción DataInvoice
DATAINVOICE_RESOLUTION_NUMBER="18760000001"
DATAINVOICE_PREFIX="SETP"
DATAINVOICE_NUMBER_FROM="990005000"
DATAINVOICE_NUMBER_TO="995000000"

# Datos del Establecimiento (Emisor)
DATAINVOICE_ESTABLISHMENT_NAME="Nombre del Establecimiento"
DATAINVOICE_ESTABLISHMENT_ADDRESS="Direccion del Establecimiento"
DATAINVOICE_ESTABLISHMENT_PHONE=3000000000
DATAINVOICE_ESTABLISHMENT_EMAIL=correo_establecimiento@dominio.com

# Parámetros Internos de Mapeo DataInvoice
DATAINVOICE_ESTABLISHMENT_MUNICIPALITY=320
DATAINVOICE_MUNICIPALITY_ID=320
DATAINVOICE_DEFAULT_EMAIL=facturacion_defecto@dominio.com
DATAINVOICE_UNIT_MEASURE_ID="70"

# Parámetros de Regulación y Envío
VALOR_UVT="52374"
DATAINVOICE_SEND_MAIL="true"
DATAINVOICE_SEND_MAIL_TO_ME="false"

# Patrón de Emisión (ALL | 1_OF_2 | 1_OF_3 | RANDOM_50)
EMISSION_PATTERN="ALL"
MAX_EDIT_HOURS="24"
